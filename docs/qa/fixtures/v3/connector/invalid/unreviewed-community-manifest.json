{
  "id": "bad-unreviewed-community",
  "version": "0.1.0",
  "displayName": "Bad Unreviewed Community",
  "trust": {
    "source": "community",
    "publisher": "community-docs",
    "manifestSha256": "sha256:5555555555555555555555555555555555555555555555555555555555555555",
    "reviewState": "repo-reviewed",
    "installScope": "user",
    "signatureRequired": true,
    "allowUnsigned": false
  },
  "operations": {
    "mode": "read-only",
    "allowedActions": ["read"],
    "writeback": false,
    "writeScopesAllowed": false,
    "runtimeWriteImplementation": "not-started"
  },
  "auth": {
    "type": "oauth2",
    "scopes": ["docs:read"],
    "tokenStorage": "keychain",
    "flow": {
      "strategy": "system-browser-loopback",
      "embeddedWebView": false,
      "callback": "loopback-127.0.0.1",
      "runtimeAuthImplementation": "not-started"
    },
    "refreshPolicy": {
      "strategy": "reauth-on-expiry",
      "backgroundRefresh": false,
      "storesRefreshToken": false,
      "runtimeRefreshImplementation": "not-started"
    }
  },
  "serviceModes": ["cloud"],
  "scopes": [
    {
      "name": "read:docs",
      "purpose": "Invalid because community manifests need security review.",
      "dataClass": "internal"
    }
  ],
  "rateLimit": {
    "perMinute": 60,
    "perDay": 1000
  },
  "evidence": {
    "emit": true,
    "category": "data-fetch"
  },
  "requiresTenantPolicy": false,
  "cacheTTLSeconds": 300
}
