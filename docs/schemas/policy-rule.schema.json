{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/policy-rule.schema.json",
  "title": "V3 Policy Rule",
  "description": "Readable policy-rule contract for V3 W4. Draft; covered by the W4 policy-tenant self-test before gated PolicyEngine implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "priority", "phase", "effect", "when", "enforcement", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^pol-[a-z0-9-]{3,80}$"
    },
    "schemaVersion": {
      "const": "v3-policy-rule/0.1"
    },
    "priority": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "phase": {
      "enum": ["pre-flight", "post-evidence"]
    },
    "effect": {
      "enum": ["allow", "deny", "require-approval", "require-evidence"]
    },
    "when": {
      "type": "object",
      "required": ["tenants", "serviceModes", "actorRoles", "targetTypes", "dataClasses"],
      "additionalProperties": false,
      "properties": {
        "tenants": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]{2,63}$"
          }
        },
        "serviceModes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["offline", "private"]
          }
        },
        "actorRoles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["user", "admin", "service", "any"]
          }
        },
        "targetTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["chat", "provider", "connector", "kb-query", "agent-step", "patch-apply", "companion", "local-cloud", "starter-pack", "edition-policy", "i18n-manual", "distribution-update", "error-recovery-ux", "perf-baseline", "crash-recovery", "release-ga-checklist"]
          }
        },
        "dataClasses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": ["public", "internal", "confidential", "secret"]
          }
        }
      }
    },
    "enforcement": {
      "type": "object",
      "required": ["blocksAction", "approvalRequired", "auditLogRequired", "reasonCode"],
      "additionalProperties": false,
      "properties": {
        "blocksAction": {
          "type": "boolean"
        },
        "approvalRequired": {
          "type": "boolean"
        },
        "auditLogRequired": {
          "const": true
        },
        "reasonCode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{3,80}$"
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "emitsAuditLog", "evidenceRecordRequired"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["policy-decision", "audit-log-entry", "evidence-record", "user-approval"]
          }
        },
        "emitsAuditLog": {
          "const": true
        },
        "evidenceRecordRequired": {
          "const": true
        }
      }
    }
  }
}
