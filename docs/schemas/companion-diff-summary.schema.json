{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/companion-diff-summary.schema.json",
  "title": "V3 Companion Diff Summary",
  "description": "Read-only mobile diff summary contract for V3 W7 Companion. Draft; covered by the W7 companion-contract self-test before gated companion implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "createdAt", "taskId", "stepResultId", "tenant", "workspace", "surface", "diff", "summary", "redaction", "mobile", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cds-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-companion-diff-summary/0.1"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^agt-[0-9a-f]{16}$"
    },
    "stepResultId": {
      "type": "string",
      "pattern": "^agsr-[0-9a-f]{16}$"
    },
    "tenant": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "surface": {
      "enum": ["writer", "calc", "impress"]
    },
    "diff": {
      "type": "object",
      "required": ["summaryKind", "applyPlanRef", "actionKind", "actionCount", "previewHash", "humanSummary", "storesDocumentContent", "mobileParsesApplyPlan"],
      "additionalProperties": false,
      "properties": {
        "summaryKind": {
          "enum": ["paragraph", "cell", "slide"]
        },
        "applyPlanRef": {
          "type": "string",
          "pattern": "^aprt-[0-9a-f]{16}$"
        },
        "actionKind": {
          "enum": ["ParagraphAction", "CellAction", "SlideElementAction"]
        },
        "actionCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 25
        },
        "previewHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "humanSummary": {
          "type": "string",
          "minLength": 8,
          "maxLength": 512
        },
        "storesDocumentContent": {
          "const": false
        },
        "mobileParsesApplyPlan": {
          "const": false
        }
      }
    },
    "summary": {
      "type": "object",
      "required": ["changedObjects", "riskLevel", "requiresApproval"],
      "additionalProperties": false,
      "properties": {
        "changedObjects": {
          "type": "array",
          "minItems": 1,
          "maxItems": 25,
          "items": {
            "type": "object",
            "required": ["kind", "objectId", "textHash"],
            "additionalProperties": false,
            "properties": {
              "kind": {
                "enum": ["paragraph", "cell", "slide"]
              },
              "objectId": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              },
              "textHash": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              }
            }
          }
        },
        "riskLevel": {
          "enum": ["low", "medium", "high"]
        },
        "requiresApproval": {
          "const": true
        }
      }
    },
    "redaction": {
      "type": "object",
      "required": ["hashAlgorithm", "snippetStorage", "containsOriginalText"],
      "additionalProperties": false,
      "properties": {
        "hashAlgorithm": {
          "const": "sha256"
        },
        "snippetStorage": {
          "enum": ["hash-only", "redacted-summary"]
        },
        "containsOriginalText": {
          "const": false
        }
      }
    },
    "mobile": {
      "type": "object",
      "required": ["cacheMode", "viewOnly", "canEdit", "offlineApproval"],
      "additionalProperties": false,
      "properties": {
        "cacheMode": {
          "const": "diff-summary-plus-evidence"
        },
        "viewOnly": {
          "const": true
        },
        "canEdit": {
          "const": false
        },
        "offlineApproval": {
          "const": false
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["companion-diff-summary", "shadow-doc-diff", "apply-plan-runtime-validated", "evidence-record", "audit-log-entry"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
