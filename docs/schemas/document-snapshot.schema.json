{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kqoffice.local/schemas/document-snapshot.schema.json",
  "title": "KQOffice Engine Capability Document Snapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "module",
    "scope",
    "revision_token",
    "locale",
    "redaction_mode",
    "size_limit",
    "content_included",
    "unsupported_content"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "m3-02"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,80}$"
    },
    "module": {
      "type": "string",
      "enum": ["writer", "calc", "impress", "draw", "shared"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary_zh"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["document", "selection", "page", "slide", "sheet", "range"]
        },
        "summary_zh": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string"
        }
      }
    },
    "revision_token": {
      "type": "string",
      "minLength": 1
    },
    "locale": {
      "type": "string",
      "enum": ["zh-CN", "zh-Hans", "en"]
    },
    "redaction_mode": {
      "type": "string",
      "enum": ["metadata-only", "selected-context", "redacted-summary"]
    },
    "size_limit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_chars", "max_objects"],
      "properties": {
        "max_chars": {
          "type": "integer"
        },
        "max_objects": {
          "type": "integer"
        }
      }
    },
    "content_included": {
      "type": "boolean",
      "const": false
    },
    "unsupported_content": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "summary_zh"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["macro", "embedded-object", "external-link", "protected-range", "speaker-notes", "unknown"]
          },
          "summary_zh": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
