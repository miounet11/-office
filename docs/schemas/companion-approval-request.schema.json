{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/companion-approval-request.schema.json",
  "title": "V3 Companion Approval Request",
  "description": "Online approval request contract for V3 W7 Companion. Draft; covered by the W7 companion-contract self-test before gated companion implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "createdAt", "expiresAt", "taskId", "summaryId", "pairingId", "tenant", "workspace", "actor", "channel", "request", "transport", "approval", "dataBoundary", "audit", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^car-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-companion-approval-request/0.1"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "expiresAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^agt-[0-9a-f]{16}$"
    },
    "summaryId": {
      "type": "string",
      "pattern": "^cds-[0-9a-f]{16}$"
    },
    "pairingId": {
      "type": "string",
      "pattern": "^cpt-[0-9a-f]{16}$"
    },
    "tenant": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "actor": {
      "type": "object",
      "required": ["userId", "role"],
      "additionalProperties": false,
      "properties": {
        "userId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9._-]{2,80}$"
        },
        "role": {
          "const": "user"
        }
      }
    },
    "channel": {
      "const": "companion"
    },
    "request": {
      "type": "object",
      "required": ["state", "availableActions", "requiresOnline"],
      "additionalProperties": false,
      "properties": {
        "state": {
          "enum": ["awaiting-review", "per-step-review", "failure-recovery"]
        },
        "availableActions": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["approve", "reject", "rollback"]
          }
        },
        "requiresOnline": {
          "const": true
        }
      }
    },
    "transport": {
      "type": "object",
      "required": ["mode", "localGatewayPort", "publicEgress", "cloudPushOptIn"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["lan-push", "enterprise-push"]
        },
        "localGatewayPort": {
          "const": 17801
        },
        "publicEgress": {
          "type": "boolean"
        },
        "cloudPushOptIn": {
          "type": "boolean"
        }
      }
    },
    "approval": {
      "type": "object",
      "required": ["biometricRequired", "secondConfirmRequired", "mobileMayEdit", "decisionWritesAudit"],
      "additionalProperties": false,
      "properties": {
        "biometricRequired": {
          "const": true
        },
        "secondConfirmRequired": {
          "const": true
        },
        "mobileMayEdit": {
          "const": false
        },
        "decisionWritesAudit": {
          "const": true
        }
      }
    },
    "dataBoundary": {
      "type": "object",
      "required": ["storesDocumentContent", "storesDiffSummaryOnly", "allowApprovalOffline"],
      "additionalProperties": false,
      "properties": {
        "storesDocumentContent": {
          "const": false
        },
        "storesDiffSummaryOnly": {
          "const": true
        },
        "allowApprovalOffline": {
          "const": false
        }
      }
    },
    "audit": {
      "type": "object",
      "required": ["auditLogRequired", "actorRole", "channel", "evidenceRequired"],
      "additionalProperties": false,
      "properties": {
        "auditLogRequired": {
          "const": true
        },
        "actorRole": {
          "const": "user"
        },
        "channel": {
          "const": "companion"
        },
        "evidenceRequired": {
          "const": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["companion-approval-request", "user-approval", "biometric-confirmation", "audit-log-entry", "evidence-record"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
