{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/knowledge-index-result.schema.json",
  "title": "V3 Knowledge Index Result",
  "description": "Synchronous W3 knowledge index result contract. Draft; covered by the W3 knowledge-index-query-result self-test before gated query runtime implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "queryId", "createdAt", "workspace", "summary", "chunks", "boundary", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^kbr-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-knowledge-index-result/0.1"
    },
    "queryId": {
      "type": "string",
      "pattern": "^kbq-[0-9a-f]{16}$"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "summary": {
      "type": "object",
      "required": ["resultCount", "latencyMs", "retrievalMode", "truncated", "storesDocumentContent"],
      "additionalProperties": false,
      "properties": {
        "resultCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "latencyMs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 500
        },
        "retrievalMode": {
          "enum": ["fts", "hybrid"]
        },
        "truncated": {
          "type": "boolean"
        },
        "storesDocumentContent": {
          "const": false
        }
      }
    },
    "chunks": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["chunkId", "rank", "scoreBasisPoints", "sourceKind", "textHash", "snippetHash", "evidenceIds"],
        "additionalProperties": false,
        "properties": {
          "chunkId": {
            "type": "string",
            "pattern": "^kbch-[0-9a-f]{16}$"
          },
          "rank": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
          },
          "scoreBasisPoints": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10000
          },
          "sourceKind": {
            "enum": ["document", "connector"]
          },
          "textHash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "snippetHash": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^ev-[0-9a-f]{16}$"
            }
          }
        }
      }
    },
    "boundary": {
      "type": "object",
      "required": ["publicEgress", "hashAlgorithm", "storesDocumentContent"],
      "additionalProperties": false,
      "properties": {
        "publicEgress": {
          "const": false
        },
        "hashAlgorithm": {
          "const": "sha256"
        },
        "storesDocumentContent": {
          "const": false
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "enum": ["kb-query", "chunk-read", "no-public-egress"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
