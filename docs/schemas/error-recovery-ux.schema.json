{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/error-recovery-ux.schema.json",
  "title": "V3 Error Recovery UX",
  "description": "Contract-first manifest for V3 W9 error recovery UX. Draft; covered by the W9 error-recovery-ux self-test before gated recovery UI or product integration exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "createdAt", "policy", "scenarios", "evidence", "gates"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^errux-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-error-recovery-ux/0.1"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "policy": {
      "type": "object",
      "required": ["presentation", "nextStepRequired", "evidenceOpenable", "deadEndAllowed", "mainDocumentUnchangedUntilApply", "humanReadableCauseRequired"],
      "additionalProperties": false,
      "properties": {
        "presentation": {
          "const": "inline-guidance"
        },
        "nextStepRequired": {
          "const": true
        },
        "evidenceOpenable": {
          "const": true
        },
        "deadEndAllowed": {
          "const": false
        },
        "mainDocumentUnchangedUntilApply": {
          "const": true
        },
        "humanReadableCauseRequired": {
          "const": true
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["kind", "surface", "causeToken", "nextSteps", "evidence", "recoveryGuarantee"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "enum": ["provider-timeout", "connector-auth-expired", "policy-denied", "patch-apply-failed"]
          },
          "surface": {
            "enum": ["writer", "calc", "impress", "companion"]
          },
          "causeToken": {
            "type": "string",
            "pattern": "^error\\.[a-z0-9-]+$"
          },
          "nextSteps": {
            "type": "array",
            "minItems": 2,
            "uniqueItems": true,
            "items": {
              "enum": ["retry", "choose-local-model", "reconnect-connector", "request-approval", "open-evidence", "rollback-preview", "open-help", "export-diagnostics"]
            }
          },
          "evidence": {
            "type": "object",
            "required": ["openable", "evidenceId", "diagnosticsExportable"],
            "additionalProperties": false,
            "properties": {
              "openable": {
                "const": true
              },
              "evidenceId": {
                "type": "string",
                "pattern": "^ev-[0-9a-f]{16}$"
              },
              "diagnosticsExportable": {
                "const": true
              }
            }
          },
          "recoveryGuarantee": {
            "type": "object",
            "required": ["mainDocumentUnchanged", "canRetry", "canRollback", "requiresUserChoice"],
            "additionalProperties": false,
            "properties": {
              "mainDocumentUnchanged": {
                "const": true
              },
              "canRetry": {
                "const": true
              },
              "canRollback": {
                "const": true
              },
              "requiresUserChoice": {
                "const": true
              }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": ["error-recovery-ux", "inline-guidance", "next-step-action", "openable-evidence", "diagnostics-export", "evidence-record", "v2-regression-green"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    },
    "gates": {
      "type": "object",
      "required": ["blocksGA", "requiresV2RegressionGreen", "runtimeImplementation"],
      "additionalProperties": false,
      "properties": {
        "blocksGA": {
          "const": true
        },
        "requiresV2RegressionGreen": {
          "const": true
        },
        "runtimeImplementation": {
          "const": "not-started"
        }
      }
    }
  }
}
