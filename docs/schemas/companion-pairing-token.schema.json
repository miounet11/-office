{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/companion-pairing-token.schema.json",
  "title": "V3 Companion Pairing Token",
  "description": "Pairing token contract for V3 W7 Companion. Draft; covered by the W7 companion-contract self-test before gated CompanionBridge or app implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "createdAt", "expiresAt", "tenant", "workspace", "desktop", "device", "transport", "token", "security", "dataBoundary", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^cpt-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-companion-pairing-token/0.1"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "expiresAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "tenant": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "desktop": {
      "type": "object",
      "required": ["instanceId", "app", "lanEndpoint"],
      "additionalProperties": false,
      "properties": {
        "instanceId": {
          "type": "string",
          "pattern": "^desk-[0-9a-f]{16}$"
        },
        "app": {
          "enum": ["writer", "calc", "impress", "start-center"]
        },
        "lanEndpoint": {
          "type": "string",
          "pattern": "^grpc://[^ ]+:17801$"
        }
      }
    },
    "device": {
      "type": "object",
      "required": ["proposedDeviceId", "platform", "bindingRequired"],
      "additionalProperties": false,
      "properties": {
        "proposedDeviceId": {
          "type": "string",
          "pattern": "^dev-[0-9a-f]{16}$"
        },
        "platform": {
          "enum": ["ios", "android", "pwa"]
        },
        "bindingRequired": {
          "const": true
        }
      }
    },
    "transport": {
      "type": "object",
      "required": ["mode", "port", "publicEgress", "cloudPushOptIn", "mdnsRequired"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["lan-grpc", "enterprise-https"]
        },
        "port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "publicEgress": {
          "type": "boolean"
        },
        "cloudPushOptIn": {
          "type": "boolean"
        },
        "mdnsRequired": {
          "type": "boolean"
        }
      }
    },
    "token": {
      "type": "object",
      "required": ["ttlSeconds", "sessionTtlHours", "hash", "storesSecret"],
      "additionalProperties": false,
      "properties": {
        "ttlSeconds": {
          "type": "integer",
          "minimum": 60,
          "maximum": 600
        },
        "sessionTtlHours": {
          "const": 24
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "storesSecret": {
          "const": false
        }
      }
    },
    "security": {
      "type": "object",
      "required": ["pinConfirmationRequired", "biometricEnrollmentRequired", "mTLSRequired", "revocable"],
      "additionalProperties": false,
      "properties": {
        "pinConfirmationRequired": {
          "const": true
        },
        "biometricEnrollmentRequired": {
          "const": true
        },
        "mTLSRequired": {
          "const": true
        },
        "revocable": {
          "const": true
        }
      }
    },
    "dataBoundary": {
      "type": "object",
      "required": ["storesDocumentContent", "storesDiffSummaryOnly", "allowApprovalOffline"],
      "additionalProperties": false,
      "properties": {
        "storesDocumentContent": {
          "const": false
        },
        "storesDiffSummaryOnly": {
          "const": true
        },
        "allowApprovalOffline": {
          "const": false
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["companion-pairing-token", "user-pin-confirmation", "device-binding", "audit-log-entry"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
