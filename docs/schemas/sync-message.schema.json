{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kqoffice.example.com/schemas/sync-message.schema.json",
  "title": "V3 Sync Message",
  "description": "Client to localcloud sync-server message contract for V3 W8. Draft; covered by the W8 sync-message self-test before gated sync runtime implementation exists.",
  "type": "object",
  "required": ["id", "schemaVersion", "createdAt", "tenant", "workspace", "channel", "direction", "kind", "payload", "transport", "ordering", "boundary", "evidence"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^sync-[0-9a-f]{16}$"
    },
    "schemaVersion": {
      "const": "v3-sync-message/0.1"
    },
    "createdAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "tenant": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "workspace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "channel": {
      "enum": ["desktop-to-sync", "sync-to-companion", "companion-to-sync", "sync-to-desktop"]
    },
    "direction": {
      "enum": ["upload", "download", "ack"]
    },
    "kind": {
      "enum": ["evidence-sync", "diff-summary-sync", "approval-decision-sync", "task-state-sync"]
    },
    "payload": {
      "type": "object",
      "required": ["refType", "refId", "hash", "storesDocumentContent", "containsRawPayload"],
      "additionalProperties": false,
      "properties": {
        "refType": {
          "enum": ["evidence-record", "companion-diff-summary", "companion-approval-request", "agent-task-state"]
        },
        "refId": {
          "type": "string",
          "pattern": "^(ev|cds|car|agt)-[0-9a-f]{16}$"
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "storesDocumentContent": {
          "const": false
        },
        "containsRawPayload": {
          "const": false
        }
      }
    },
    "transport": {
      "type": "object",
      "required": ["mode", "endpointClass", "port", "publicEgress", "mTLSRequired"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["local-socket", "lan-grpc"]
        },
        "endpointClass": {
          "enum": ["loopback", "private-lan"]
        },
        "port": {
          "const": 17802
        },
        "publicEgress": {
          "const": false
        },
        "mTLSRequired": {
          "const": true
        }
      }
    },
    "ordering": {
      "type": "object",
      "required": ["sequence", "idempotencyKey", "ackRequired"],
      "additionalProperties": false,
      "properties": {
        "sequence": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2147483647
        },
        "idempotencyKey": {
          "type": "string",
          "pattern": "^idem-[0-9a-f]{16}$"
        },
        "ackRequired": {
          "const": true
        }
      }
    },
    "boundary": {
      "type": "object",
      "required": ["serviceMode", "storesDocumentContent", "hashOnly", "defaultNoPublicEgress"],
      "additionalProperties": false,
      "properties": {
        "serviceMode": {
          "enum": ["offline", "private"]
        },
        "storesDocumentContent": {
          "const": false
        },
        "hashOnly": {
          "const": true
        },
        "defaultNoPublicEgress": {
          "const": true
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": ["required", "evidenceIds"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": ["localcloud-sync-message", "evidence-record", "audit-log-entry", "companion-diff-summary", "companion-approval-request", "agent-task-state"]
          }
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^ev-[0-9a-f]{16}$"
          }
        }
      }
    }
  }
}
