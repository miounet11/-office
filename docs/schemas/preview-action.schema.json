{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kqoffice.local/schemas/preview-action.schema.json",
  "title": "KQOffice Engine Capability Preview Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "capability_id",
    "module",
    "affected_scope",
    "before_summary_zh",
    "after_summary_zh",
    "risk_level",
    "service_mode",
    "apply_preconditions",
    "undo_supported",
    "unsupported_cases",
    "evidence_record_id"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "m3-02"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,80}$"
    },
    "capability_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,80}$"
    },
    "module": {
      "type": "string",
      "enum": ["writer", "calc", "impress", "draw", "shared"]
    },
    "affected_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "summary_zh"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["document", "selection", "page", "slide", "sheet", "range", "object"]
        },
        "summary_zh": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "before_summary_zh": {
      "type": "string",
      "minLength": 1
    },
    "after_summary_zh": {
      "type": "string",
      "minLength": 1
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "blocked"]
    },
    "service_mode": {
      "type": "string",
      "enum": ["offline", "local", "private", "cloud"]
    },
    "apply_preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["document-revision-match", "preview-visible", "user-accepted", "undo-group-ready", "policy-allowed"]
      },
      "uniqueItems": true
    },
    "undo_supported": {
      "type": "boolean"
    },
    "unsupported_cases": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["macros", "protected-content", "external-links", "unsupported-notes", "unknown-layout"]
      },
      "uniqueItems": true
    },
    "evidence_record_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]{2,80}$"
    }
  }
}
